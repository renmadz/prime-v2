# ─────────────────────────────────────────────────────────
# PRIME v2 — Environment Variables
#
# Copy this file to .env and fill in real values.
# .env is in .gitignore — never commit it.
# This file contains ONLY placeholder values — safe to commit.
# ─────────────────────────────────────────────────────────

# App environment
NODE_ENV=development
# Options: development | staging | production

# ─────────────────────────────────────────────────────────
# URLs
# ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000
# In staging/production these become the real HTTPS domain URLs.
# GOOGLE_CALLBACK_URL must exactly match the URI registered in
# Google Cloud Console for the OAuth 2.0 client.
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─────────────────────────────────────────────────────────
# Session
# ─────────────────────────────────────────────────────────
# Minimum 64 random bytes, base64 or hex encoded.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-at-least-64-random-bytes

# ─────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────
POSTGRES_DB=primev2
POSTGRES_USER=primev2_user
POSTGRES_PASSWORD=replace-with-strong-password
# Full connection string used by the backend ORM/query layer
DATABASE_URL=postgresql://primev2_user:replace-with-strong-password@prime-postgres:5432/primev2

# ─────────────────────────────────────────────────────────
# MinIO
# ─────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET_NAME=prime-attachments
# Endpoint used internally by the backend service
# (service name on the Docker network — do not change unless service name changes)
# MINIO_ENDPOINT is hardcoded as prime-minio in docker-compose.yml

# ─────────────────────────────────────────────────────────
# Google OAuth 2.0
# ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret
# Register credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly.
