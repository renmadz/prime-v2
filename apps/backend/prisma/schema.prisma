// PRIME v2 — Prisma schema (Phase 8: Proposals, Form Templates, Attachments)
// Table/column names match docs/database/PRIME-v2-ERD.md and DATA-DICTIONARY.md exactly.
// Phase 7 models are unchanged; Phase 8 models appended below.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid()) @db.Uuid
  email               String   @unique @db.VarChar(320)
  googleId            String?  @unique @map("google_id") @db.VarChar(255)
  passwordHash        String?  @map("password_hash")
  firstName           String   @map("first_name") @db.VarChar(100)
  lastName            String   @map("last_name") @db.VarChar(100)
  displayName         String?  @map("display_name") @db.VarChar(200)
  isActive            Boolean  @default(true) @map("is_active")
  mustChangePassword  Boolean  @default(false) @map("must_change_password")
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  userRoles           UserRole[]           @relation("UserRoles")
  rolesAssignedByMe   UserRole[]           @relation("RoleAssignedBy")
  invitations         UserInvitation[]
  passwordResetTokens PasswordResetToken[]
  applicantProfile    ApplicantProfile?
  staffProfile        StaffProfile?
  auditLogs           AuditLog[]

  // Phase 8 relations
  publishedVersions   FormTemplateVersion[] @relation("PublishedVersions")
  applicantProposals  Proposal[]            @relation("ApplicantProposals")
  createdVersions     ProposalVersion[]     @relation("CreatedVersions")
  fieldValueChanges   ProposalFieldValue[]  @relation("FieldValueChanges")
  uploadedAttachments ProposalAttachment[]  @relation("UploadedAttachments")
  proposalAssignments ProposalAssignment[]  @relation("ProposalAssignments")
  assignedProposals   ProposalAssignment[]  @relation("AssignedByUser")

  // Phase 9 relations
  authoredComments    ProposalComment[] @relation("CommentAuthor")
  resolvedComments    ProposalComment[] @relation("CommentResolver")

  @@index([email])
  @@index([googleId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?
  isActive    Boolean  @default(true) @map("is_active")

  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz()
  assignedBy String?  @map("assigned_by") @db.Uuid

  user       User     @relation("UserRoles", fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])
  assignedByUser User? @relation("RoleAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model UserInvitation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_invitations")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

model ApplicantProfile {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  institution          String?   @db.VarChar(255)
  positionTitle        String?   @map("position_title") @db.VarChar(255)
  contactNumber        String?   @map("contact_number") @db.VarChar(50)
  address              String?   @db.VarChar(500)
  privacyConsentGiven  Boolean   @default(false) @map("privacy_consent_given")
  privacyConsentAt     DateTime? @map("privacy_consent_at") @db.Timestamptz()

  user                 User      @relation(fields: [userId], references: [id])

  @@map("applicant_profiles")
}

model StaffProfile {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String  @unique @map("user_id") @db.Uuid
  officeId       String? @map("office_id") @db.Uuid
  office         Office? @relation(fields: [officeId], references: [id])
  positionTitle  String? @map("position_title") @db.VarChar(255)
  employeeNumber String? @map("employee_number") @db.VarChar(100)

  user           User    @relation(fields: [userId], references: [id])

  @@map("staff_profiles")
}

model AuditLog {
  id                String   @id @default(uuid()) @db.Uuid
  actorUserId       String?  @map("actor_user_id") @db.Uuid
  actorRole         String?  @map("actor_role") @db.VarChar(50)
  action            String   @db.VarChar(100)
  entityType        String   @map("entity_type") @db.VarChar(100)
  entityId          String?  @map("entity_id") @db.Uuid
  beforeState       String?  @map("before_state")
  afterState        String?  @map("after_state")
  ipAddress         String?  @map("ip_address") @db.VarChar(45)
  sessionReference  String?  @map("session_reference") @db.VarChar(255)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  actorUser         User?    @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Phase 8 Models ───────────────────────────────────────────────────────────

model Office {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  code      String    @unique @db.VarChar(50)
  isActive  Boolean   @default(true) @map("is_active")

  programs        Program[]
  staffProfiles   StaffProfile[]

  @@map("offices")
}

model Program {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  code      String    @unique @db.VarChar(50)
  officeId  String    @map("office_id") @db.Uuid
  isActive  Boolean   @default(true) @map("is_active")

  office        Office          @relation(fields: [officeId], references: [id])
  proposalTypes ProposalType[]

  @@map("programs")
}

model ProposalType {
  id                    String    @id @default(uuid()) @db.Uuid
  code                  String    @unique @db.VarChar(50)
  name                  String    @db.VarChar(255)
  programId             String    @map("program_id") @db.Uuid
  defaultFormTemplateId String?   @map("default_form_template_id") @db.Uuid
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  program             Program       @relation(fields: [programId], references: [id])
  defaultFormTemplate FormTemplate? @relation(fields: [defaultFormTemplateId], references: [id])
  proposals           Proposal[]

  @@map("proposal_types")
}

model FormTemplate {
  id              String    @id @default(uuid()) @db.Uuid
  formCode        String    @unique @map("form_code") @db.VarChar(50)
  title           String    @db.VarChar(255)
  sourceType      String?   @map("source_type") @db.VarChar(20)
  sourceFilename  String?   @map("source_filename") @db.VarChar(255)
  programCode     String?   @map("program_code") @db.VarChar(20)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  versions      FormTemplateVersion[]
  proposalTypes ProposalType[]

  @@map("form_templates")
}

model FormTemplateVersion {
  id               String    @id @default(uuid()) @db.Uuid
  formTemplateId   String    @map("form_template_id") @db.Uuid
  versionNumber    Int       @map("version_number")
  schemaVersion    String    @map("schema_version") @db.VarChar(20)
  isCurrent        Boolean   @default(false) @map("is_current")
  publishedAt      DateTime? @map("published_at") @db.Timestamptz()
  publishedBy      String?   @map("published_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  formTemplate      FormTemplate     @relation(fields: [formTemplateId], references: [id])
  publisher         User?            @relation("PublishedVersions", fields: [publishedBy], references: [id])
  sections          FormSection[]
  calculations      FormCalculation[]
  proposalVersions  ProposalVersion[]

  @@map("form_template_versions")
}

model FormSection {
  id                    String    @id @default(uuid()) @db.Uuid
  formTemplateVersionId String    @map("form_template_version_id") @db.Uuid
  sectionCode           String    @map("section_code") @db.VarChar(50)
  title                 String    @db.VarChar(255)
  displayOrder          Int       @map("display_order")
  isRepeating           Boolean   @default(false) @map("is_repeating")
  isRequired            Boolean   @default(true) @map("is_required")

  formTemplateVersion FormTemplateVersion @relation(fields: [formTemplateVersionId], references: [id])
  fields              FormField[]

  // Phase 9 relations
  comments            ProposalComment[]

  @@map("form_sections")
}

model FormField {
  id                 String    @id @default(uuid()) @db.Uuid
  formSectionId      String    @map("form_section_id") @db.Uuid
  fieldCode          String    @map("field_code") @db.VarChar(50)
  label              String    @db.VarChar(255)
  inputType          String    @map("input_type") @db.VarChar(20)
  isRequired         Boolean   @default(false) @map("is_required")
  validationRules    String?   @map("validation_rules")
  calculationFormula String?   @map("calculation_formula")
  displayOrder       Int       @map("display_order")
  isCommentable      Boolean   @default(false) @map("is_commentable")

  formSection       FormSection          @relation(fields: [formSectionId], references: [id])
  fieldValues       ProposalFieldValue[]

  // Phase 9 relations
  comments            ProposalComment[]

  @@map("form_fields")
}

model FormCalculation {
  id                    String @id @default(uuid()) @db.Uuid
  formTemplateVersionId String @map("form_template_version_id") @db.Uuid
  calculationCode       String @map("calculation_code") @db.VarChar(50)
  formulaDescription    String @map("formula_description")
  targetFieldCode       String @map("target_field_code") @db.VarChar(50)

  formTemplateVersion FormTemplateVersion @relation(fields: [formTemplateVersionId], references: [id])

  @@map("form_calculations")
}

model Proposal {
  id               String    @id @default(uuid()) @db.Uuid
  applicantUserId  String    @map("applicant_user_id") @db.Uuid
  proposalTypeId   String    @map("proposal_type_id") @db.Uuid
  status           String    @default("DRAFT") @db.VarChar(50)
  title            String    @db.VarChar(500)
  currentVersionId String?   @map("current_version_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  submittedAt      DateTime? @map("submitted_at") @db.Timestamptz()
  isLocked         Boolean   @default(false) @map("is_locked")

  applicant        User             @relation("ApplicantProposals", fields: [applicantUserId], references: [id])
  proposalType     ProposalType     @relation(fields: [proposalTypeId], references: [id])
  versions         ProposalVersion[] @relation("ProposalVersions")
  currentVersion   ProposalVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  attachments      ProposalAttachment[]
  assignments      ProposalAssignment[]

  // Phase 9 relations
  comments            ProposalComment[]

  @@index([applicantUserId])
  @@index([status])
  @@index([proposalTypeId])
  @@map("proposals")
}

model ProposalVersion {
  id                    String    @id @default(uuid()) @db.Uuid
  proposalId            String    @map("proposal_id") @db.Uuid
  versionNumber         Int       @map("version_number")
  formTemplateVersionId String    @map("form_template_version_id") @db.Uuid
  createdBy             String    @map("created_by") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  submittedAt           DateTime? @map("submitted_at") @db.Timestamptz()
  sourceVersionId       String?   @map("source_version_id") @db.Uuid
  statusAtCreation      String    @map("status_at_creation") @db.VarChar(50)
  changeSummary         String?   @map("change_summary")
  isSubmitted           Boolean   @default(false) @map("is_submitted")

  proposal              Proposal             @relation("ProposalVersions", fields: [proposalId], references: [id])
  formTemplateVersion   FormTemplateVersion  @relation(fields: [formTemplateVersionId], references: [id])
  creator               User                 @relation("CreatedVersions", fields: [createdBy], references: [id])
  sourceVersion         ProposalVersion?     @relation("VersionSource", fields: [sourceVersionId], references: [id])
  derivedVersions       ProposalVersion[]    @relation("VersionSource")
  fieldValues           ProposalFieldValue[]
  attachments           ProposalAttachment[]
  currentForProposals   Proposal[]           @relation("CurrentVersion")

  // Phase 9 relations
  comments            ProposalComment[]

  @@index([proposalId])
  @@index([versionNumber])
  @@map("proposal_versions")
}

model ProposalFieldValue {
  id                String    @id @default(uuid()) @db.Uuid
  proposalVersionId String    @map("proposal_version_id") @db.Uuid
  formFieldId       String    @map("form_field_id") @db.Uuid
  value             String?
  previousValue     String?   @map("previous_value")
  changedBy         String?   @map("changed_by") @db.Uuid
  changedAt         DateTime? @map("changed_at") @db.Timestamptz()
  changeReason      String?   @map("change_reason")

  proposalVersion ProposalVersion @relation(fields: [proposalVersionId], references: [id])
  formField       FormField       @relation(fields: [formFieldId], references: [id])
  changedByUser   User?           @relation("FieldValueChanges", fields: [changedBy], references: [id])

  @@unique([proposalVersionId, formFieldId])
  @@index([proposalVersionId])
  @@index([formFieldId])
  @@map("proposal_field_values")
}

model ProposalAttachment {
  id                String    @id @default(uuid()) @db.Uuid
  proposalId        String    @map("proposal_id") @db.Uuid
  proposalVersionId String    @map("proposal_version_id") @db.Uuid
  minioKey          String    @map("minio_key") @db.VarChar(500)
  originalFilename  String    @map("original_filename") @db.VarChar(255)
  contentType       String    @map("content_type") @db.VarChar(100)
  sizeBytes         BigInt    @map("size_bytes")
  uploadedBy        String    @map("uploaded_by") @db.Uuid
  uploadedAt        DateTime  @default(now()) @map("uploaded_at") @db.Timestamptz()
  isDeleted         Boolean   @default(false) @map("is_deleted")

  proposal        Proposal        @relation(fields: [proposalId], references: [id])
  proposalVersion ProposalVersion @relation(fields: [proposalVersionId], references: [id])
  uploader        User            @relation("UploadedAttachments", fields: [uploadedBy], references: [id])

  @@index([proposalId])
  @@index([proposalVersionId])
  @@map("proposal_attachments")
}

model ProposalAssignment {
  id          String    @id @default(uuid()) @db.Uuid
  proposalId  String    @map("proposal_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  roleCode    String    @map("role_code") @db.VarChar(50)
  assignedAt  DateTime  @default(now()) @map("assigned_at") @db.Timestamptz()
  assignedBy  String    @map("assigned_by") @db.Uuid
  isActive    Boolean   @default(true) @map("is_active")

  proposal    Proposal @relation(fields: [proposalId], references: [id])
  user        User     @relation("ProposalAssignments", fields: [userId], references: [id])
  assigner    User     @relation("AssignedByUser", fields: [assignedBy], references: [id])

  @@index([proposalId])
  @@index([roleCode])
  @@index([isActive])
  @@map("proposal_assignments")
}

// ─── Phase 9 Models ───────────────────────────────────────────────────────────

model ProposalComment {
  id                  String    @id @default(uuid()) @db.Uuid
  proposalId          String    @map("proposal_id") @db.Uuid
  proposalVersionId   String    @map("proposal_version_id") @db.Uuid
  authorUserId        String    @map("author_user_id") @db.Uuid
  commentType         String    @map("comment_type") @db.VarChar(20)
  visibility          String    @db.VarChar(20)
  targetFieldId       String?   @map("target_field_id") @db.Uuid
  targetSectionId     String?   @map("target_section_id") @db.Uuid
  body                String
  isResolved          Boolean   @default(false) @map("is_resolved")
  resolvedBy          String?   @map("resolved_by") @db.Uuid
  resolvedAt          DateTime? @map("resolved_at") @db.Timestamptz()
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  proposal          Proposal        @relation(fields: [proposalId], references: [id])
  proposalVersion   ProposalVersion @relation(fields: [proposalVersionId], references: [id])
  author            User            @relation("CommentAuthor", fields: [authorUserId], references: [id])
  resolver          User?           @relation("CommentResolver", fields: [resolvedBy], references: [id])
  targetField       FormField?      @relation(fields: [targetFieldId], references: [id])
  targetSection     FormSection?    @relation(fields: [targetSectionId], references: [id])

  @@index([proposalId])
  @@index([proposalVersionId])
  @@index([authorUserId])
  @@index([isResolved])
  @@map("proposal_comments")
}
